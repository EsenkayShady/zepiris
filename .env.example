# Copy to .env and adjust. All app settings use prefix ZEPIRIS_ (see config.py).

ZEPIRIS_API_HOST=0.0.0.0
ZEPIRIS_API_PORT=8000

ZEPIRIS_MINIO_ENDPOINT=localhost:9002
ZEPIRIS_MINIO_ACCESS_KEY=minioadmin
ZEPIRIS_MINIO_SECRET_KEY=minioadmin
ZEPIRIS_MINIO_BUCKET=zepiris
ZEPIRIS_MINIO_SECURE=false

ZEPIRIS_MILVUS_HOST=localhost
ZEPIRIS_MILVUS_PORT=19530
ZEPIRIS_MILVUS_COLLECTION=zepiris_faces
ZEPIRIS_MILVUS_EMBEDDING_DIM=512
ZEPIRIS_MILVUS_SEARCH_THRESHOLD=0.5

# Required: ML inference for POST /v1/iqa/assess and POST /v1/face/embed (see docker-compose)
ZEPIRIS_ML_INFERENCE_SERVICE_URL=http://localhost:8001

# ML Inference Microservice (separate container, env prefix ML_SERVICE_)
# See zepiris/ml_inference/app.py
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8001
ML_SERVICE_ML_DEVICE=cpu

ML_SERVICE_NSFW_MODEL_SOURCE=local
ML_SERVICE_NSFW_HF_REPO_ID=
ML_SERVICE_NSFW_HF_MODEL_FILE=nsfw_model.pth
ML_SERVICE_NSFW_LOCAL_MODEL_PATH=/app/models/nsfw_model.pth
ML_SERVICE_NSFW_THRESHOLD=0.5

ML_SERVICE_SPOOF_MODEL_SOURCE=local
ML_SERVICE_SPOOF_HF_REPO_ID=
ML_SERVICE_SPOOF_HF_MODEL_FILE=spoof_model.pth
ML_SERVICE_SPOOF_LOCAL_MODEL_PATH=/app/models/spoof_model.pth
ML_SERVICE_SPOOF_THRESHOLD=0.5

ML_SERVICE_BLUR_MODEL_SOURCE=local
ML_SERVICE_BLUR_HF_REPO_ID=
ML_SERVICE_BLUR_HF_MODEL_FILE=blur_model.pth
ML_SERVICE_BLUR_LOCAL_MODEL_PATH=/app/models/blur_model.pth
ML_SERVICE_BLUR_THRESHOLD=0.5

ML_SERVICE_FACE_MODEL=auraface
# Setting this to "auraface" uses fal/AuraFace-v1 model for face detection and embedding generation. Other acceptable value(s): "buffalo_l" sets the model to InsightFace's buffalo_l.
# NOTE: The use of InsightFace's buffalo_l model weights are licensed for non-commercial research purposes only. Commercial use requires a separate license. Contact: recognition-oss-pack@insightface.ai

ML_SERVICE_FACE_EMBEDDING_DIM=512
ML_SERVICE_FACE_DETECTION_WIDTH=640
ML_SERVICE_FACE_DETECTION_HEIGHT=640
ML_SERVICE_FACE_AREA_THRESHOLD=0.01
